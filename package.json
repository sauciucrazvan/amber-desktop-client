{
  "name": "amber-desktop-app",
  "private": true,
  "version": "26.5.0",
  "author": "Răzvan Sauciuc",
  "description": "The last communication app you'll ever need.",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 vite",
    "build": "node scripts/build.mjs",
    "build:all": "node scripts/build.mjs --all",
    "build:linux": "node scripts/build.mjs --linux",
    "build:win": "node scripts/build.mjs --win",
    "build:publish:github": "node scripts/build.mjs --all --publish --publish-provider=github --git-release-notes",
    "build:publish:github:windows": "node scripts/build.mjs --win --publish --publish-provider=github --git-release-notes",
    "build:publish:generic": "node scripts/build.mjs --all --publish --publish-provider=generic",
    "build:static": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/simple-peer": "^9.11.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^25.7.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.0",
    "simple-peer": "^9.11.1",
    "sonner": "^2.0.7",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "overrides": {
    "tar": "^7.5.3"
  },
  "main": "dist-electron/main.js"
}
